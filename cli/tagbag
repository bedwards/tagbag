# ─── Login Command ───────────────────────────────────────────────────────────

TAGBAG_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/tagbag"
CREDS_FILE="${TAGBAG_CONFIG_DIR}/credentials.json"

load_credentials() {
    if [[ -f "$CREDS_FILE" ]]; then
        [[ -z "$GITEA_TOKEN" ]] && GITEA_TOKEN=$(jq -r '.gitea_token // empty' "$CREDS_FILE" 2>/dev/null)
        [[ -z "$PLANE_API_TOKEN" ]] && PLANE_API_TOKEN=$(jq -r '.plane_token // empty' "$CREDS_FILE" 2>/dev/null)
        [[ -z "$WOODPECKER_TOKEN" ]] && WOODPECKER_TOKEN=$(jq -r '.woodpecker_token // empty' "$CREDS_FILE" 2>/dev/null)
    fi
}

save_credentials() {
    mkdir -p "$TAGBAG_CONFIG_DIR"
    jq -n \
        --arg g "${GITEA_TOKEN}" \
        --arg p "${PLANE_API_TOKEN}" \
        --arg w "${WOODPECKER_TOKEN}" \
        --arg gu "${GITEA_URL}" \
        --arg pu "${PLANE_URL}" \
        --arg wu "${WOODPECKER_URL}" \
        '{gitea_token: $g, plane_token: $p, woodpecker_token: $w, gitea_url: $gu, plane_url: $pu, woodpecker_url: $wu}' \
        > "$CREDS_FILE"
    chmod 600 "$CREDS_FILE"
    info "Credentials saved to ${CREDS_FILE}"
}

cmd_login() {
    local auto=false
    local gitea_user="${TAGBAG_GITEA_USER:-tagbag}"
    local gitea_pass="${TAGBAG_GITEA_PASS:-tagbag123}"
    local token_name="${TAGBAG_TOKEN_NAME:-tagbag-auto}"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --auto)        auto=true; shift ;;
            --gitea-user)  [[ -n "$2" && "$2" != --* ]] || die "Option '--gitea-user' requires an argument."; gitea_user="$2"; shift 2 ;;
            --gitea-pass)  [[ -n "$2" && "$2" != --* ]] || die "Option '--gitea-pass' requires an argument."; gitea_pass="$2"; shift 2 ;;
            --token-name)  [[ -n "$2" && "$2" != --* ]] || die "Option '--token-name' requires an argument."; token_name="$2"; shift 2 ;;
            *)             die "Unknown login option: $1" ;;
        esac
    done

    if [[ "$auto" == "true" ]]; then
        cmd_login_auto "$gitea_user" "$gitea_pass" "$token_name"
        return
    fi

    cat <<'EOF'
tagbag login — configure tokens for all three services

EOF
    echo -e "${BOLD}Step 1: Gitea token${NC}"
    echo "  Create at: ${GITEA_URL}/user/settings/applications"
    echo "  Scopes: write:repository, write:issue, read:organization, read:user"
    echo ""
    read -rp "  Gitea token: " GITEA_TOKEN
    if [[ -n "$GITEA_TOKEN" ]]; then
        local user
        user=$(curl -sf -H "Authorization: token $GITEA_TOKEN" "${GITEA_URL}/api/v1/user" | jq -r '.login // empty')
        if [[ -n "$user" ]]; then
            echo -e "  ${GREEN}Authenticated as: ${user}${NC}"
        else
            warn "Could not verify Gitea token (is Gitea running?)"
        fi
    fi

    echo ""
    echo -e "${BOLD}Step 2: Plane API token${NC}"
    echo "  Create at: ${PLANE_URL} → Workspace Settings → API Tokens"
    echo ""
    read -rp "  Plane API token: " PLANE_API_TOKEN
    if [[ -n "$PLANE_API_TOKEN" ]]; then
        local plane_user
        plane_user=$(curl -sf -H "X-Api-Key: $PLANE_API_TOKEN" "${PLANE_URL}/api/v1/users/me/" | jq -r '.display_name // empty')
        if [[ -n "$plane_user" ]]; then
            echo -e "  ${GREEN}Authenticated as: ${plane_user}${NC}"
        else
            warn "Could not verify Plane token (is Plane running?)"
        fi
    fi

    echo ""
    echo -e "${BOLD}Step 3: Woodpecker token${NC}"
    echo "  Create at: ${WOODPECKER_URL} → User icon → Personal Access Token"
    echo "  (Log in via Gitea OAuth first)"
    echo ""
    read -rp "  Woodpecker token: " WOODPECKER_TOKEN
    if [[ -n "$WOODPECKER_TOKEN" ]]; then
        local wp_user
        wp_user=$(curl -sf -H "Authorization: Bearer $WOODPECKER_TOKEN" "${WOODPECKER_URL}/api/user" | jq -r '.login // empty')
        if [[ -n "$wp_user" ]]; then
            echo -e "  ${GREEN}Authenticated as: ${wp_user}${NC}"
        else
            warn "Could not verify Woodpecker token (is Woodpecker running?)"
        fi
    fi

    echo ""
    _login_save_config
}

cmd_login_auto() {
    local gitea_user="$1" gitea_pass="$2" token_name="$3"

    info "Non-interactive login — creating tokens automatically"
    echo ""

    # ── Step 1: Gitea API token ──────────────────────────────────────────────
    echo -e "${BOLD}Step 1: Gitea API token${NC}"

    # Delete any existing token with the same name (ignore errors)
    curl -sf -X DELETE \
        -u "${gitea_user}:${gitea_pass}" \
        "${GITEA_URL}/api/v1/users/${gitea_user}/tokens/${token_name}" \
        >/dev/null 2>&1 || true

    local gitea_resp
    gitea_resp=$(curl -sf -X POST \
        "${GITEA_URL}/api/v1/users/${gitea_user}/tokens" \
        -u "${gitea_user}:${gitea_pass}" \
        -H 'Content-Type: application/json' \
        -d "{\"name\":\"${token_name}\",\"scopes\":[\"write:repository\",\"write:issue\",\"read:organization\",\"read:user\"]}" 2>/dev/null) || true

    if [[ -n "$gitea_resp" ]]; then
        GITEA_TOKEN=$(echo "$gitea_resp" | jq -r '.sha1 // .token // empty')
        if [[ -n "$GITEA_TOKEN" ]]; then
            echo -e "  ${GREEN}Gitea token created for user: ${gitea_user}${NC}"
        else
            warn "Gitea responded but no token field found in response"
            warn "Response: ${gitea_resp}"
        fi
    else
        warn "Could not create Gitea token (is Gitea running at ${GITEA_URL}?)"
    fi

    # ── Step 2: Plane API token ──────────────────────────────────────────────
    echo ""
    echo -e "${BOLD}Step 2: Plane API token${NC}"

    if curl -s "${PLANE_URL}/api/v1/users/me/" &>/dev/null; then
        # Plane is up, but we cannot create API tokens via the API without
        # an existing token or admin credentials. Check if a token is already
        # configured in the environment.
        if [[ -n "$PLANE_API_TOKEN" ]]; then
            local plane_user
            plane_user=$(curl -sf -H "X-Api-Key: $PLANE_API_TOKEN" \
                "${PLANE_URL}/api/v1/users/me/" 2>/dev/null | jq -r '.display_name // empty' 2>/dev/null)
            if [[ -n "$plane_user" ]]; then
                echo -e "  ${GREEN}Using existing Plane token (user: ${plane_user})${NC}"
            else
                warn "Existing PLANE_API_TOKEN is invalid; clearing it"
                PLANE_API_TOKEN=""
            fi
        else
            warn "Plane is running but API tokens must be created in the web UI"
            echo "  Visit: ${PLANE_URL} -> Workspace Settings -> API Tokens"
            echo "  Then run: tagbag login (interactive) or set PLANE_API_TOKEN"
        fi
    else
        warn "Plane is not reachable at ${PLANE_URL} — skipping"
    fi

    # ── Step 3: Woodpecker token ─────────────────────────────────────────────
    echo ""
    echo -e "${BOLD}Step 3: Woodpecker token${NC}"

    if [[ -n "$WOODPECKER_TOKEN" ]]; then
        local wp_user
        wp_user=$(curl -sf -H "Authorization: Bearer $WOODPECKER_TOKEN" \
            "${WOODPECKER_URL}/api/user" 2>/dev/null | jq -r '.login // empty' 2>/dev/null)
        if [[ -n "$wp_user" ]]; then
            echo -e "  ${GREEN}Using existing Woodpecker token (user: ${wp_user})${NC}"
        else
            warn "Existing WOODPECKER_TOKEN is invalid; clearing it"
            WOODPECKER_TOKEN=""
        fi
    else
        warn "Woodpecker tokens require OAuth login via Gitea first"
        echo "  1. Open ${WOODPECKER_URL} and log in with your Gitea account"
        echo "  2. Go to User icon -> Personal Access Token"
        echo "  3. Then run: tagbag login (interactive) or set WOODPECKER_TOKEN"
    fi

    echo ""
    _login_save_config
}

_login_save_config() {
    save_credentials

    # Also write the config file
    mkdir -p "$TAGBAG_CONFIG_DIR"
    cat > "${TAGBAG_CONFIG_DIR}/config" <<CONF
# TagBag config — generated by tagbag login
GITEA_URL=${GITEA_URL}
PLANE_URL=${PLANE_URL}
WOODPECKER_URL=${WOODPECKER_URL}
GITEA_TOKEN=${GITEA_TOKEN}
PLANE_API_TOKEN=${PLANE_API_TOKEN}
WOODPECKER_TOKEN=${WOODPECKER_TOKEN}
TAGBAG_CLONE_DIR=${TAGBAG_CLONE_DIR}
TAGBAG_COMPOSE_DIR=${TAGBAG_COMPOSE_DIR}
CONF
    chmod 600 "${TAGBAG_CONFIG_DIR}/config"

    echo ""
    echo -e "${BOLD}Done!${NC} Config saved to ${TAGBAG_CONFIG_DIR}/config"
    echo "Credentials saved to ${CREDS_FILE}"
}

cmd_whoami() {
    echo -e "${BOLD}TagBag Identity${NC}"
    echo ""
    if [[ -n "$GITEA_TOKEN" ]]; then
        local g
        g=$(curl -sf -H "Authorization: token $GITEA_TOKEN" "${GITEA_URL}/api/v1/user" 2>/dev/null | jq -r '"\(.login) <\(.email)>"' 2>/dev/null)
        echo "  Gitea:      ${g:-not authenticated}"
    else
        echo "  Gitea:      no token"
    fi
    if [[ -n "$PLANE_API_TOKEN" ]]; then
        local p
        p=$(curl -sf -H "X-Api-Key: $PLANE_API_TOKEN" "${PLANE_URL}/api/v1/users/me/" 2>/dev/null | jq -r '.display_name // empty' 2>/dev/null)
        echo "  Plane:      ${p:-not authenticated}"
    else
        echo "  Plane:      no token"
    fi
    if [[ -n "$WOODPECKER_TOKEN" ]]; then
        local w
        w=$(curl -sf -H "Authorization: Bearer $WOODPECKER_TOKEN" "${WOODPECKER_URL}/api/user" 2>/dev/null | jq -r '.login // empty' 2>/dev/null)
        echo "  Woodpecker: ${w:-not authenticated}"
    else
        echo "  Woodpecker: no token"
    fi
}

# ─── Main ────────────────────────────────────────────────────────────────────

main() {
    # Parse global options
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --plane-url)       PLANE_URL="$2"; shift 2 ;;
            --plane-token)     PLANE_API_TOKEN="$2"; shift 2 ;;
            --gitea-url)       GITEA_URL="$2"; shift 2 ;;
            --gitea-token)     GITEA_TOKEN="$2"; shift 2 ;;
            --woodpecker-url)  WOODPECKER_URL="$2"; shift 2 ;;
            --woodpecker-token) WOODPECKER_TOKEN="$2"; shift 2 ;;
            --json)            OUTPUT_JSON=true; shift ;;
            --quiet|-q)        QUIET=true; shift ;;
            --help|-h)         show_help; exit 0 ;;
            --)                shift; break ;;
            -*)                die "Unknown global option: $1" ;;
            *)                 break ;;
        esac
    done

    # Load saved credentials (env vars take precedence)
    load_credentials

    local cmd="${1:-help}"
    shift 2>/dev/null || true

    case "$cmd" in
        help|--help|-h) show_help ;;
        login)          cmd_login "$@" ;;
        whoami)         cmd_whoami ;;
        status)         cmd_status ;;
        up)             cmd_up "$@" ;;
        down)           cmd_down "$@" ;;
        build)          cmd_build "$@" ;;
        logs)           cmd_logs "$@" ;;
        clone)          cmd_clone "$@" ;;
        web)            cmd_web ;;
        push)           cmd_push "$@" ;;
        reviewer)       cmd_reviewer "$@" ;;
        bridge)         cmd_bridge "$@" ;;
        plane)          cmd_plane "$@" ;;
        gitea)          cmd_gitea "$@" ;;
        ci)             cmd_ci "$@" ;;
        *)              die "Unknown command: $cmd. Run 'tagbag --help'." ;;
    esac
}

main "$@"
