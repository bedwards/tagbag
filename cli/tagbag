# ─── Plane Commands ──────────────────────────────────────────────────────────

plane_help() {
    cat <<'EOF'
tagbag plane — Plane issue tracker commands

Usage: tagbag plane <subcommand> [args...]

Subcommands:
  workspaces              List workspaces
  projects <workspace>    List projects in a workspace
  work-items <workspace> <project>
                          List work items (issues)
  work-item <workspace> <project> <id>
                          Get work item details (UUID or PROJ-123)
  create-work-item <workspace> <project> [opts]
                          Create a work item
    --name NAME           Title (required)
    --description DESC    HTML description
    --priority PRIORITY   none|urgent|high|medium|low
    --state STATE-ID      State UUID
    --assignee USER-ID    Assignee UUID (repeatable)
    --label LABEL-ID      Label UUID (repeatable)
  update-work-item <workspace> <project> <id> [opts]
                          Update a work item (same opts as create)
  delete-work-item <workspace> <project> <id>
                          Delete a work item
  search <workspace> --query TEXT [--limit N]
                          Search work items across projects
  states <workspace> <project>
                          List workflow states
  labels <workspace> <project>
                          List labels
  cycles <workspace> <project>
                          List cycles/sprints
  modules <workspace> <project>
                          List modules
  members <workspace>     List workspace members
  comments <workspace> <project> <work-item-id>
                          List comments on a work item
  add-comment <workspace> <project> <work-item-id> --body TEXT
                          Add a comment to a work item
  me                      Show current authenticated user

Run 'tagbag plane <subcommand> --help' for more details.
EOF
}

cmd_plane() {
    local subcmd="${1:-help}"
    shift 2>/dev/null || true

    case "$subcmd" in
        help|--help|-h) plane_help ;;

        me)
            plane_api GET "/users/me/" | jq '.' ;;

        workspaces)
            plane_api GET "/workspaces/" | jq '.' ;;

        projects)
            local ws="${1:?Usage: tagbag plane projects <workspace-slug>}"
            plane_api GET "/workspaces/${ws}/projects/" | jq '.' ;;

        work-items)
            local ws="${1:?Usage: tagbag plane work-items <workspace> <project-id>}"
            local proj="${2:?Usage: tagbag plane work-items <workspace> <project-id>}"
            shift 2
            local extra=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --expand)  extra="${extra}&expand=$2"; shift 2 ;;
                    --order)   extra="${extra}&order_by=$2"; shift 2 ;;
                    --fields)  extra="${extra}&fields=$2"; shift 2 ;;
                    *)         break ;;
                esac
            done
            plane_api GET "/workspaces/${ws}/projects/${proj}/work-items/?${extra#&}" | jq '.' ;;

        work-item)
            local ws="${1:?Usage: tagbag plane work-item <workspace> <project-id|PROJ-123> <id>}"
            local second="$2"
            # Support PROJ-123 shorthand (workspace-level lookup)
            if [[ "$second" =~ ^[A-Z]+-[0-9]+$ ]]; then
                plane_api GET "/workspaces/${ws}/work-items/${second}/" | jq '.'
            else
                local proj="$second"
                local iid="${3:?}"
                plane_api GET "/workspaces/${ws}/projects/${proj}/work-items/${iid}/" | jq '.'
            fi
            ;;

        search)
            local ws="${1:?Usage: tagbag plane search <workspace> --query TEXT}"
            shift
            local query="" limit="20"
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --query|-q) query="$2"; shift 2 ;;
                    --limit)    limit="$2"; shift 2 ;;
                    *)          die "Unknown option: $1" ;;
                esac
            done
            [[ -n "$query" ]] || die "--query is required"
            plane_api GET "/workspaces/${ws}/work-items/search/?search=$(printf '%s' "$query" | jq -sRr @uri)&limit=${limit}" | jq '.' ;;

        create-work-item)
            local ws="${1:?Usage: tagbag plane create-work-item <workspace> <project-id> --name ...}"
            local proj="${2:?}"
            shift 2
            local name="" desc="" priority="" state="" assignees="[]" labels="[]"
            local -a assignee_arr=() label_arr=()
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --name)       name="$2"; shift 2 ;;
                    --description) desc="$2"; shift 2 ;;
                    --priority)   priority="$2"; shift 2 ;;
                    --state)      state="$2"; shift 2 ;;
                    --assignee)   assignee_arr+=("\"$2\""); shift 2 ;;
                    --label)      label_arr+=("\"$2\""); shift 2 ;;
                    --)           shift; break ;;
                    *)            die "Unknown option: $1" ;;
                esac
            done
            [[ -n "$name" ]] || die "--name is required"
            if [[ ${#assignee_arr[@]} -gt 0 ]]; then
                assignees="[$(IFS=,; echo "${assignee_arr[*]}")]"
            fi
            if [[ ${#label_arr[@]} -gt 0 ]]; then
                labels="[$(IFS=,; echo "${label_arr[*]}")]"
            fi
            local body
            body=$(jq -n \
                --arg name "$name" \
                --arg desc "$desc" \
                --arg priority "$priority" \
                --arg state "$state" \
                --argjson assignees "$assignees" \
                --argjson labels "$labels" \
                '{name: $name} +
                 (if $desc != "" then {description_html: $desc} else {} end) +
                 (if $priority != "" then {priority: $priority} else {} end) +
                 (if $state != "" then {state: $state} else {} end) +
                 (if ($assignees | length) > 0 then {assignees: $assignees} else {} end) +
                 (if ($labels | length) > 0 then {labels: $labels} else {} end)')
            plane_api POST "/workspaces/${ws}/projects/${proj}/work-items/" -d "$body" | jq '.' ;;

        update-work-item)
            local ws="${1:?Usage: tagbag plane update-work-item <workspace> <project-id> <id> --name ...}"
            local proj="${2:?}"
            local iid="${3:?}"
            shift 3
            local body="{}"
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --name)        body=$(echo "$body" | jq --arg v "$2" '. + {name: $v}'); shift 2 ;;
                    --description) body=$(echo "$body" | jq --arg v "$2" '. + {description_html: $v}'); shift 2 ;;
                    --priority)    body=$(echo "$body" | jq --arg v "$2" '. + {priority: $v}'); shift 2 ;;
                    --state)       body=$(echo "$body" | jq --arg v "$2" '. + {state: $v}'); shift 2 ;;
                    --)            shift; break ;;
                    *)             die "Unknown option: $1" ;;
                esac
            done
            plane_api PATCH "/workspaces/${ws}/projects/${proj}/work-items/${iid}/" -d "$body" | jq '.' ;;

        delete-work-item)
            local ws="${1:?Usage: tagbag plane delete-work-item <workspace> <project-id> <id>}"
            local proj="${2:?}"
            local iid="${3:?}"
            plane_api DELETE "/workspaces/${ws}/projects/${proj}/work-items/${iid}/" ;;

        states)
            local ws="${1:?Usage: tagbag plane states <workspace> <project-id>}"
            local proj="${2:?}"
            plane_api GET "/workspaces/${ws}/projects/${proj}/states/" | jq '.' ;;

        labels)
            local ws="${1:?Usage: tagbag plane labels <workspace> <project-id>}"
            local proj="${2:?}"
            plane_api GET "/workspaces/${ws}/projects/${proj}/labels/" | jq '.' ;;

        cycles)
            local ws="${1:?Usage: tagbag plane cycles <workspace> <project-id>}"
            local proj="${2:?}"
            plane_api GET "/workspaces/${ws}/projects/${proj}/cycles/" | jq '.' ;;

        modules)
            local ws="${1:?Usage: tagbag plane modules <workspace> <project-id>}"
            local proj="${2:?}"
            plane_api GET "/workspaces/${ws}/projects/${proj}/modules/" | jq '.' ;;

        members)
            local ws="${1:?Usage: tagbag plane members <workspace-slug>}"
            plane_api GET "/workspaces/${ws}/members/" | jq '.' ;;

        comments)
            local ws="${1:?Usage: tagbag plane comments <workspace> <project-id> <work-item-id>}"
            local proj="${2:?}"
            local iid="${3:?}"
            plane_api GET "/workspaces/${ws}/projects/${proj}/work-items/${iid}/comments/" | jq '.' ;;

        add-comment)
            local ws="${1:?Usage: tagbag plane add-comment <workspace> <project-id> <work-item-id> --body TEXT}"
            local proj="${2:?}"
            local iid="${3:?}"
            shift 3
            local body_text=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --body) body_text="$2"; shift 2 ;;
                    *)      die "Unknown option: $1" ;;
                esac
            done
            [[ -n "$body_text" ]] || die "--body is required"
            local payload
            payload=$(jq -n --arg b "$body_text" '{comment_html: $b}')
            plane_api POST "/workspaces/${ws}/projects/${proj}/work-items/${iid}/comments/" -d "$payload" | jq '.' ;;

        activities)
            local ws="${1:?Usage: tagbag plane activities <workspace> <project-id> <work-item-id>}"
            local proj="${2:?}"
            local iid="${3:?}"
            plane_api GET "/workspaces/${ws}/projects/${proj}/work-items/${iid}/activities/" | jq '.' ;;

        *) die "Unknown plane subcommand: $subcmd. Run 'tagbag plane --help'." ;;
    esac
}

# ─── Gitea Commands (wraps tea CLI) ─────────────────────────────────────────

gitea_help() {
    cat <<'EOF'
tagbag gitea — Gitea commands (wraps tea CLI + raw API)

Usage: tagbag gitea <subcommand> [args...] [-- tea-args]

Subcommands:
  repos                   List repos
  repo <owner/name>       Get repo details
  create-repo [opts]      Create a repo
    --name NAME           Repo name (required)
    --description DESC    Description
    --private             Make private
  prs <owner/repo>        List pull requests
  pr <owner/repo> <num>   Get PR details
  create-pr <owner/repo> [opts]
                          Create a pull request
    --title TITLE         PR title (required)
    --body BODY           PR description
    --head BRANCH         Head branch (required)
    --base BRANCH         Base branch (default: main)
  merge-pr <owner/repo> <num> [--method merge|rebase|squash]
                          Merge a pull request
  clone-url <owner/repo> [--ssh]
                          Get clone URL (HTTPS default, --ssh for SSH)
  issues <owner/repo>     List issues
  webhooks <owner/repo>   List webhooks
  orgs                    List organizations
  users                   List users (admin)
  tea [args...]           Pass-through to tea CLI
  api <method> <path> [curl-args...]
                          Raw Gitea API call

Everything after -- is passed directly to tea.
EOF
}

cmd_gitea() {
    local subcmd="${1:-help}"
    shift 2>/dev/null || true

    case "$subcmd" in
        help|--help|-h) gitea_help ;;

        repos)
            gitea_api GET "/user/repos" | jq '.[] | {full_name, html_url, private, updated_at}' ;;

        repo)
            local repo="${1:?Usage: tagbag gitea repo <owner/name>}"
            gitea_api GET "/repos/${repo}" | jq '.' ;;

        clone-url)
            local repo="${1:?Usage: tagbag gitea clone-url <owner/name> [--ssh]}"
            shift
            local use_ssh=false
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --ssh) use_ssh=true; shift ;;
                    *)     break ;;
                esac
            done
            if [[ "$use_ssh" == "true" ]]; then
                gitea_api GET "/repos/${repo}" | jq -r '.ssh_url'
            else
                gitea_api GET "/repos/${repo}" | jq -r '.clone_url'
            fi
            ;;

        create-repo)
            local name="" desc="" private="false"
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --name)        name="$2"; shift 2 ;;
                    --description) desc="$2"; shift 2 ;;
                    --private)     private="true"; shift ;;
                    *)             die "Unknown option: $1" ;;
                esac
            done
            [[ -n "$name" ]] || die "--name is required"
            local body
            body=$(jq -n --arg n "$name" --arg d "$desc" --argjson p "$private" \
                '{name: $n, description: $d, private: $p}')
            gitea_api POST "/user/repos" -d "$body" | jq '{full_name, html_url, clone_url, ssh_url}' ;;

        prs)
            local repo="${1:?Usage: tagbag gitea prs <owner/repo>}"
            gitea_api GET "/repos/${repo}/pulls?state=open" | jq '.[] | {number, title, user: .user.login, head: .head.ref, base: .base.ref, state}' ;;

        pr)
            local repo="${1:?Usage: tagbag gitea pr <owner/repo> <number>}"
            local num="${2:?}"
            gitea_api GET "/repos/${repo}/pulls/${num}" | jq '.' ;;

        create-pr)
            local repo="${1:?Usage: tagbag gitea create-pr <owner/repo> --title ... --head ...}"
            shift
            local title="" body="" head="" base="main"
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --title) title="$2"; shift 2 ;;
                    --body)  body="$2"; shift 2 ;;
                    --head)  head="$2"; shift 2 ;;
                    --base)  base="$2"; shift 2 ;;
                    --)      shift; break ;;
                    *)       die "Unknown option: $1" ;;
                esac
            done
            [[ -n "$title" ]] || die "--title is required"
            [[ -n "$head" ]] || die "--head is required"
            local payload
            payload=$(jq -n --arg t "$title" --arg b "$body" --arg h "$head" --arg ba "$base" \
                '{title: $t, body: $b, head: $h, base: $ba}')
            gitea_api POST "/repos/${repo}/pulls" -d "$payload" | jq '{number, title, html_url}' ;;

        merge-pr)
            local repo="${1:?Usage: tagbag gitea merge-pr <owner/repo> <number>}"
            local num="${2:?}"
            shift 2
            local method="merge"
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --method) method="$2"; shift 2 ;;
                    *)        die "Unknown option: $1" ;;
                esac
            done
            local payload
            payload=$(jq -n --arg m "$method" '{Do: $m}')
            gitea_api POST "/repos/${repo}/pulls/${num}/merge" -d "$payload" | jq '.' ;;

        issues)
            local repo="${1:?Usage: tagbag gitea issues <owner/repo>}"
            gitea_api GET "/repos/${repo}/issues?type=issues&state=open" | jq '.[] | {number, title, user: .user.login, state, labels: [.labels[].name]}' ;;

        webhooks)
            local repo="${1:?Usage: tagbag gitea webhooks <owner/repo>}"
            gitea_api GET "/repos/${repo}/hooks" | jq '.' ;;

        orgs)
            gitea_api GET "/user/orgs" | jq '.[] | {username, full_name, description}' ;;

        users)
            gitea_api GET "/admin/users" | jq '.[] | {id, login, email, is_admin}' ;;

        tea)
            exec tea "$@" ;;

        api)
            local method="${1:?Usage: tagbag gitea api <METHOD> <path> [curl-args...]}"
            local path="${2:?}"
            shift 2
            gitea_api "$method" "$path" "$@" | jq '.' 2>/dev/null || true ;;

        *) die "Unknown gitea subcommand: $subcmd. Run 'tagbag gitea --help'." ;;
    esac
}

# ─── Woodpecker CI Commands (wraps woodpecker-cli + raw API) ────────────────

ci_help() {
    cat <<'EOF'
tagbag ci — Woodpecker CI commands (wraps woodpecker-cli + raw API)

Usage: tagbag ci <subcommand> [args...] [-- woodpecker-cli-args]

Subcommands:
  repos                   List activated repos
  repo <owner/name>       Get repo details
  activate <owner/name>   Activate a repo
  pipelines <owner/name>  List pipelines
  pipeline <owner/name> <num>
                          Get pipeline details
  logs <owner/name> <pipeline> <step>
                          Get step logs
  trigger <owner/name> [--branch BRANCH]
                          Trigger a pipeline
  stop <owner/name> <pipeline>
                          Stop a pipeline
  secrets <owner/name>    List repo secrets
  add-secret <owner/name> --name NAME --value VALUE
                          Add a repo secret
  rm-secret <owner/name> <secret-name>
                          Remove a repo secret
  info                    Server info
  wp [args...]            Pass-through to woodpecker-cli
  api <method> <path> [curl-args...]
                          Raw Woodpecker API call

Everything after -- is passed directly to woodpecker-cli.
EOF
}

cmd_ci() {
    local subcmd="${1:-help}"
    shift 2>/dev/null || true

    case "$subcmd" in
        help|--help|-h) ci_help ;;

        repos)
            woodpecker_api GET "/user/repos" | jq '.[] | {id, full_name, active}' ;;

        repo)
            local repo="${1:?Usage: tagbag ci repo <owner/name>}"
            woodpecker_api GET "/repos/lookup/${repo}" | jq '.' ;;

        activate)
            local repo="${1:?Usage: tagbag ci activate <owner/name>}"
            woodpecker_api POST "/repos" -d "$(jq -n --arg f "$repo" '{forge_remote_id: $f}')" | jq '.' ;;

        pipelines)
            local repo="${1:?Usage: tagbag ci pipelines <owner/name>}"
            local repo_id
            repo_id=$(woodpecker_api GET "/repos/lookup/${repo}" | jq -r '.id')
            woodpecker_api GET "/repos/${repo_id}/pipelines" | jq '.[] | {number, status, event, branch: .branch, message: .message}' ;;

        pipeline)
            local repo="${1:?}"
            local num="${2:?Usage: tagbag ci pipeline <owner/name> <number>}"
            local repo_id
            repo_id=$(woodpecker_api GET "/repos/lookup/${repo}" | jq -r '.id')
            woodpecker_api GET "/repos/${repo_id}/pipelines/${num}" | jq '.' ;;

        logs)
            local repo="${1:?}"
            local pipeline="${2:?}"
            local step="${3:?Usage: tagbag ci logs <owner/name> <pipeline> <step>}"
            local repo_id
            repo_id=$(woodpecker_api GET "/repos/lookup/${repo}" | jq -r '.id')
            woodpecker_api GET "/repos/${repo_id}/logs/${pipeline}/${step}" | jq -r '.[].data' ;;

        trigger)
            local repo="${1:?Usage: tagbag ci trigger <owner/name>}"
            shift
            local branch="main"
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --branch) branch="$2"; shift 2 ;;
                    *)        die "Unknown option: $1" ;;
                esac
            done
            local repo_id
            repo_id=$(woodpecker_api GET "/repos/lookup/${repo}" | jq -r '.id')
            woodpecker_api POST "/repos/${repo_id}/pipelines" -d "$(jq -n --arg b "$branch" '{branch: $b}')" | jq '{number, status, event}' ;;

        stop)
            local repo="${1:?}"
            local num="${2:?Usage: tagbag ci stop <owner/name> <pipeline-number>}"
            local repo_id
            repo_id=$(woodpecker_api GET "/repos/lookup/${repo}" | jq -r '.id')
            woodpecker_api POST "/repos/${repo_id}/pipelines/${num}/cancel" | jq '.' ;;

        secrets)
            local repo="${1:?Usage: tagbag ci secrets <owner/name>}"
            local repo_id
            repo_id=$(woodpecker_api GET "/repos/lookup/${repo}" | jq -r '.id')
            woodpecker_api GET "/repos/${repo_id}/secrets" | jq '.[] | {name, event}' ;;

        add-secret)
            local repo="${1:?Usage: tagbag ci add-secret <owner/name> --name NAME --value VALUE}"
            shift
            local name="" value=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --name)  name="$2"; shift 2 ;;
                    --value) value="$2"; shift 2 ;;
                    *)       die "Unknown option: $1" ;;
                esac
            done
            [[ -n "$name" ]] || die "--name required"
            [[ -n "$value" ]] || die "--value required"
            local repo_id
            repo_id=$(woodpecker_api GET "/repos/lookup/${repo}" | jq -r '.id')
            woodpecker_api POST "/repos/${repo_id}/secrets" \
                -d "$(jq -n --arg n "$name" --arg v "$value" '{name: $n, value: $v, event: ["push","pull_request","tag","deployment"]}')" | jq '.' ;;

        rm-secret)
            local repo="${1:?}"
            local name="${2:?Usage: tagbag ci rm-secret <owner/name> <secret-name>}"
            local repo_id
            repo_id=$(woodpecker_api GET "/repos/lookup/${repo}" | jq -r '.id')
            woodpecker_api DELETE "/repos/${repo_id}/secrets/${name}" ;;

        info)
            woodpecker_api GET "/version" | jq '.' ;;

        wp)
            exec woodpecker-cli "$@" ;;

        api)
            local method="${1:?Usage: tagbag ci api <METHOD> <path> [curl-args...]}"
            local path="${2:?}"
            shift 2
            woodpecker_api "$method" "$path" "$@" | jq '.' 2>/dev/null || true ;;

        *) die "Unknown ci subcommand: $subcmd. Run 'tagbag ci --help'." ;;
    esac
}

