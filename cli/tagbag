#!/usr/bin/env bash
#
# tagbag — unified CLI for TagBag (Gitea + Plane + Woodpecker)
#
# Usage: tagbag [global-opts] <command> [command-opts] [subcommand] [args...] [-- wrapped-args]
#
# Global options:
#   --plane-url URL       Plane API base URL (default: http://localhost:8080)
#   --plane-token TOKEN   Plane API token (or PLANE_API_TOKEN env)
#   --gitea-url URL       Gitea base URL (default: http://localhost:3000)
#   --gitea-token TOKEN   Gitea API token (or GITEA_TOKEN env)
#   --woodpecker-url URL  Woodpecker base URL (default: http://localhost:9080)
#   --woodpecker-token TK Woodpecker API token (or WOODPECKER_TOKEN env)
#   --json                Output JSON (default for API commands)
#   --quiet               Suppress non-essential output
#   --help                Show help
#
set -euo pipefail

# ─── Config Loading ──────────────────────────────────────────────────────────

# Load config from ~/.config/tagbag/config (env vars override)
TAGBAG_CONFIG="${TAGBAG_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/tagbag/config}"
if [[ -f "$TAGBAG_CONFIG" ]]; then
    # shellcheck source=/dev/null
    source "$TAGBAG_CONFIG"
fi

# ─── Defaults (env vars override config file) ───────────────────────────────

PLANE_URL="${PLANE_URL:-http://localhost:8080}"
PLANE_API_TOKEN="${PLANE_API_TOKEN:-}"
GITEA_URL="${GITEA_URL:-http://localhost:3000}"
GITEA_TOKEN="${GITEA_TOKEN:-}"
WOODPECKER_URL="${WOODPECKER_URL:-http://localhost:9080}"
WOODPECKER_TOKEN="${WOODPECKER_TOKEN:-}"
TAGBAG_CLONE_DIR="${TAGBAG_CLONE_DIR:-${HOME}/vibe/tagbag-clones}"
TAGBAG_COMPOSE_DIR="${TAGBAG_COMPOSE_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
export OUTPUT_JSON=false
QUIET=false

# ─── Colors ──────────────────────────────────────────────────────────────────

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# ─── Helpers ─────────────────────────────────────────────────────────────────

die()  { echo -e "${RED}error:${NC} $*" >&2; exit 1; }
info() { [[ "$QUIET" == "true" ]] || echo -e "${CYAN}$*${NC}" >&2; }
warn() { echo -e "${YELLOW}warning:${NC} $*" >&2; }

require_plane_token() {
    [[ -n "$PLANE_API_TOKEN" ]] || die "PLANE_API_TOKEN not set. Export it or pass --plane-token."
}

require_gitea_token() {
    [[ -n "$GITEA_TOKEN" ]] || die "GITEA_TOKEN not set. Export it or pass --gitea-token."
}

require_woodpecker_token() {
    [[ -n "$WOODPECKER_TOKEN" ]] || die "WOODPECKER_TOKEN not set. Export it or pass --woodpecker-token."
}

# Plane API helper
plane_api() {
    local method="$1" path="$2"
    shift 2
    require_plane_token
    curl -sf -X "$method" \
        -H "Content-Type: application/json" \
        -H "X-Api-Key: $PLANE_API_TOKEN" \
        "$@" \
        "${PLANE_URL}/api/v1${path}"
}

# Gitea API helper
gitea_api() {
    local method="$1" path="$2"
    shift 2
    require_gitea_token
    curl -sf -X "$method" \
        -H "Content-Type: application/json" \
        -H "Authorization: token $GITEA_TOKEN" \
        "$@" \
        "${GITEA_URL}/api/v1${path}"
}

# Woodpecker API helper
woodpecker_api() {
    local method="$1" path="$2"
    shift 2
    require_woodpecker_token
    curl -sf -X "$method" \
        -H "Content-Type: application/json" \
        -H "Authorization: Bearer $WOODPECKER_TOKEN" \
        "$@" \
        "${WOODPECKER_URL}/api${path}"
}

# ─── Help ────────────────────────────────────────────────────────────────────

show_help() {
    cat <<'EOF'
tagbag — unified CLI for TagBag (Gitea + Plane + Woodpecker)

Usage: tagbag [global-opts] <command> [subcommand] [args...] [-- wrapped-args]

Global options:
