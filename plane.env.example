# Plane API environment
# Copy to plane.env and customize: cp plane.env.example plane.env
DEBUG=0
CORS_ALLOWED_ORIGINS=http://localhost:8080

# Database
POSTGRES_USER=plane
POSTGRES_PASSWORD=changeme-postgres-password
POSTGRES_HOST=postgres
POSTGRES_DB=plane
POSTGRES_PORT=5432
DATABASE_URL=postgresql://plane:changeme-postgres-password@postgres:5432/plane

# Redis
REDIS_HOST=plane-redis
REDIS_PORT=6379
REDIS_URL=redis://plane-redis:6379/

# RabbitMQ
RABBITMQ_HOST=plane-mq
RABBITMQ_PORT=5672
RABBITMQ_USER=plane
RABBITMQ_PASSWORD=changeme-rabbitmq-password
RABBITMQ_VHOST=plane
AMQP_URL=amqp://plane:changeme-rabbitmq-password@plane-mq:5672/plane

# S3 / MinIO
AWS_REGION=
AWS_ACCESS_KEY_ID=access-key
AWS_SECRET_ACCESS_KEY=secret-key
AWS_S3_ENDPOINT_URL=http://plane-minio:9000
AWS_S3_BUCKET_NAME=uploads
FILE_SIZE_LIMIT=5242880
USE_MINIO=1
MINIO_ENDPOINT_SSL=0
SIGNED_URL_EXPIRATION=3600

# Application
SECRET_KEY=changeme-generate-a-random-secret-key
GUNICORN_WORKERS=2

# URLs (routed through Caddy proxy on port 8080)
WEB_URL=http://localhost:8080
ADMIN_BASE_URL=http://localhost:8080
ADMIN_BASE_PATH=/god-mode
SPACE_BASE_URL=http://localhost:8080
SPACE_BASE_PATH=/spaces
APP_BASE_URL=http://localhost:8080
APP_BASE_PATH=
LIVE_BASE_URL=http://localhost:8080
LIVE_BASE_PATH=/live
LIVE_SERVER_SECRET_KEY=changeme-live-secret-key

HARD_DELETE_AFTER_DAYS=60
API_KEY_RATE_LIMIT=60/minute

# Gitea OAuth2 (SSO — set after creating OAuth app in Gitea)
GITEA_HOST=http://gitea:3000
GITEA_CLIENT_ID=
GITEA_CLIENT_SECRET=
ENABLE_GITEA_SYNC=1
